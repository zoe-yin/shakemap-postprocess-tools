    areas = []
    for i in range(len(bin_edges) - 1):
        lo = bin_edges[i]
        hi = bin_edges[i + 1]

        # Left-inclusive, right-exclusive except last bin
        if i == len(bin_edges) - 2:
            mask = finite & (data >= lo) & (data <= hi)
        else:
