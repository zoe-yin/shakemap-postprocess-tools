    """

    # -------------------------------
    # Get shape
    # -------------------------------
    ny, nx = datasets[0].shape[1:]
    n_px = ny * nx

    # -------------------------------
    # Stack all datasets
    # -------------------------------
    D_list = []
    G_list = []
    sigma_list = []

    for ds in datasets:
        arr = ds.data  # (bands, ny, nx)

        # Flatten
        d = arr[0].ravel()  # observation
        G = np.stack([
            arr[1].ravel(),
            arr[2].ravel(),
            arr[3].ravel()
        ], axis=1)  # (n_px, 3)

        D_list.append(d)
        G_list.append(G)

        # Handle weights
        if use_weights and arr.shape[0] >= 5:
            sigma = arr[4].ravel()
        else:
            sigma = np.ones(n_px)

        sigma_list.append(sigma)

    print(f"len D_list: {len(D_list)}")

    # Stack into full system
    D = np.stack(D_list, axis=1)         # (n_px, n_obs)
    G = np.stack(G_list, axis=1)         # (n_px, n_obs, 3)
    sigma = np.stack(sigma_list, axis=1) # (n_px, n_obs)

    n_obs = D.shape[1]
    print(f"shape D: {D.shape}")
    print(f"shape G: {G.shape}")

    # -------------------------------
    # Initialize outputs
    # -------------------------------
    m = np.full((n_px, 3), np.nan)

    if return_std:
        m_std = np.full((n_px, 3), np.nan)

    # -------------------------------
    # Per-pixel inversion
    # -------------------------------
    for i in range(n_px):
        di = D[i]        # (n_obs,)
        Gi = G[i]        # (n_obs, 3)
        sigi = sigma[i]  # (n_obs,)

