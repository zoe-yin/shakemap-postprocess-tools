def area_density(values, area_grid, x_vals):
    """
    Estimate area density (km² per MMI) using histogram normalization.
    """
    mask = ~np.isnan(values)
    vals = values[mask]
    areas = area_grid[mask]

    hist, edges = np.histogram(
        vals,
        bins=x_vals,
        weights=areas,
        density=False
    )

    centers = 0.5 * (edges[:-1] + edges[1:])
    return centers, hist

