    # Build clean GeoTIFF metadata
    meta = {
        "driver": "GTiff",
        "height": src.height,
        "width": src.width,
        "count": 1,
        "dtype": "float32",
        "crs": src.crs,
        "transform": src.transform,
        "compress": "deflate"
    }

with rasterio.open(output_tif, "w", **meta) as dst:
    dst.write(wrapped_phase, 1)

print("Wrapped phase written to:", output_tif)
