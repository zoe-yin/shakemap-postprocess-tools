import numpy as np
from obspy.imaging.beachball import MomentTensor
from obspy.imaging.beachball import mt2axes

def compute_gamma(mt):
    M = MomentTensor(
        mt["mrr"], mt["mtt"], mt["mpp"],
        mt["mrt"], mt["mrp"], mt["mtp"]
    )

    # Convert to principal axes
    axes = mt2axes(M)

    # Eigenvalues (T, N, P)
    eigs = np.array([axes[0].val, axes[1].val, axes[2].val])

    # Normalize
    eigs = eigs / np.max(np.abs(eigs))

    # Approximate gamma (simple proxy)
    gamma = np.arctan2(
        np.sqrt(3) * (eigs[1]),
        (eigs[0] - eigs[2])
    )

    return np.degrees(gamma)
