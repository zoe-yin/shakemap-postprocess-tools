import os

merge_dir = '/Volumes/T9_InSAR/2026-04-14_nevada/S1_A014_gmtsar/F2/intf/2026092_2026104/'
filetypes = ["imagfilt_ll", "realfilt_ll","corr_ll", "los_ll", "los_ll_dtr", "xphase_mask_ll", "yphase_mask_ll", "phasefilt_ll","phasefilt_mask_ll"]    # "los_ll", "xphase_mask_ll", "yphase_mask_ll", "phasefilt_ll"

