a1 = c1.getData()
a2 = c2.getData()
ratio = a1 / a2
dif = a1 - a2
lats = np.linspace(cutdict.ymin, cutdict.ymax, ratio.shape[0])
lons = np.linspace(cutdict.xmin, cutdict.xmax, ratio.shape[1])

