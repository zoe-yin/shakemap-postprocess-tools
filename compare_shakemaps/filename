import numpy as np

def displacement_inversion(datasets, eps=1e-4, use_weights=True, return_std=False):
    """
    Per-pixel inversion from multiple 4- or 5-band rioxarray datasets.

    Each dataset must have:
        band 0: observed displacement
        band 1: east look vector (G_E)
        band 2: north look vector (G_N)
        band 3: up look vector (G_U)
        band 4 (optional): sigma (uncertainty)

    Parameters
    ----------
    datasets : list of rioxarray.DataArray
    eps : float
        Regularization parameter
    use_weights : bool
        Use band 4 as sigma if available
    return_std : bool
        Return per-parameter uncertainty

    Returns
    -------
    de, dn, du : 2D arrays
    (optional) std_e, std_n, std_u
    """

    # -------------------------------
    # Get shape
    # -------------------------------
    ny, nx = datasets[0].shape[1:]
    n_px = ny * nx

    # -------------------------------
    # Stack all datasets
    # -------------------------------
    D_list = []
    G_list = []
    sigma_list = []

    for ds in datasets:
        arr = ds.data  # (bands, ny, nx)

        # Flatten
        d = arr[0].ravel()  # observation
        G = np.stack([
            arr[1].ravel(),
            arr[2].ravel(),
            arr[3].ravel()
        ], axis=1)  # (n_px, 3)

        D_list.append(d)
        G_list.append(G)

        # Handle weights
        if use_weights and arr.shape[0] >= 5:
            sigma = arr[4].ravel()
        else:
            sigma = np.ones(n_px)

        sigma_list.append(sigma)

    # Stack into full system
    D = np.stack(D_list, axis=1)         # (n_px, n_obs)
    G = np.stack(G_list, axis=1)         # (n_px, n_obs, 3)
    sigma = np.stack(sigma_list, axis=1) # (n_px, n_obs)

    n_obs = D.shape[1]

    # -------------------------------
    # Initialize outputs
    # -------------------------------
    m = np.full((n_px, 3), np.nan)

    if return_std:
        m_std = np.full((n_px, 3), np.nan)

    # -------------------------------
    # Per-pixel inversion
    # -------------------------------
    for i in range(n_px):
        di = D[i]        # (n_obs,)
        Gi = G[i]        # (n_obs, 3)
        sigi = sigma[i]  # (n_obs,)

        valid = np.isfinite(di) & np.isfinite(Gi).all(axis=1) & np.isfinite(sigi)

        if np.sum(valid) >= 1:
            dv = di[valid]
            Gv = Gi[valid]
            sigv = sigi[valid]

            if use_weights:
                W = np.diag(1.0 / sigv**2)
            else:
                W = np.eye(len(dv))

            GTWG = Gv.T @ W @ Gv + eps * np.eye(3)
            GTWd = Gv.T @ W @ dv

            try:
                mi = np.linalg.solve(GTWG, GTWd)
                m[i] = mi

                if return_std:
                    Cov = np.linalg.inv(GTWG)
                    m_std[i] = np.sqrt(np.diag(Cov))

            except np.linalg.LinAlgError:
                continue

    # -------------------------------
    # Reshape outputs
    # -------------------------------
    de = m[:, 0].reshape(ny, nx)
    dn = m[:, 1].reshape(ny, nx)
    du = m[:, 2].reshape(ny, nx)

    if return_std:
        std_e = m_std[:, 0].reshape(ny, nx)
        std_n = m_std[:, 1].reshape(ny, nx)
        std_u = m_std[:, 2].reshape(ny, nx)
        return de, dn, du, std_e, std_n, std_u

    return de, dn, du

