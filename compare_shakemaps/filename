    # Handle MaskedArray -> NaN
    # data = arr.filled(np.nan) if np.ma.isMaskedArray(arr) else arr
    data = arr
    finite = np.isfinite(data)

    total_area = area_grid[finite].sum()

    areas = []
    for i in range(len(bin_edges) - 1):
