def classify_event(row):
    if row["depth_km"] >= 200:
        return "sub_intraslab"
    elif row["ProbabilitySubductionInterface"] >= 0.5:
        return "sub_interface"
    elif row["ProbabilitySubductionIntraslab"] >= 0.5:
        return "sub_intraslab"
    elif row["ProbabilityActive"] >= 0.5:
            if row["FocalMechanism"] == "SS":
