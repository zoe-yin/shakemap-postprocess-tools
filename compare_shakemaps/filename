def moment(mu, area, slip):
    """
    Compute seismic moment (M0).

    Parameters
    ----------
    mu : float
        Rigidity (Pa)
    area : float
        Fault area (m^2)
    slip : float
        Average slip (m)

    Returns
    -------
    float
        Seismic moment (N·m)
    """
    return mu * area * slip


